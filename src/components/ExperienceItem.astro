---
interface Props {
    date: string;
    title: string;
    company: string;
    description: string;
    technologies?: string[];
    current?: boolean;
}
const { date, title, company, description, technologies = [], current = false } = Astro.props;
---

<article class="experience-card group">
    <div class="flex flex-col md:flex-row gap-4">
        <!-- Fecha y estado -->
        <div class="md:w-32 flex-shrink-0">
            <div class="flex items-center gap-2 md:flex-col md:items-start">
                {current && (
                    <span class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium bg-green-500/20 text-green-400 rounded-full border border-green-500/30">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                        </span>
                        Actual
                    </span>
                )}
                <time class="text-sm text-slate-500 font-mono">{date}</time>
            </div>
        </div>

        <!-- Contenido principal -->
        <div class="flex-1">
            <!-- Header -->
            <div class="mb-3">
                <h3 class="text-xl font-bold text-slate-100 group-hover:text-cyan-300 transition-colors">
                    {title}
                </h3>
                <p class="text-cyan-400 font-medium flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 21l18 0"></path>
                        <path d="M9 8l1 0"></path>
                        <path d="M9 12l1 0"></path>
                        <path d="M9 16l1 0"></path>
                        <path d="M14 8l1 0"></path>
                        <path d="M14 12l1 0"></path>
                        <path d="M14 16l1 0"></path>
                        <path d="M5 21v-16a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v16"></path>
                    </svg>
                    {company}
                </p>
            </div>

            <!-- Descripción -->
            <p class="text-slate-400 mb-4 leading-relaxed">
                {description}
            </p>

            <!-- Tecnologías -->
            {technologies.length > 0 && (
                <div class="flex flex-wrap gap-2">
                    {technologies.map(tech => (
                        <span class="text-xs px-3 py-1 bg-cyan-500/10 border border-cyan-500/20 rounded-full text-cyan-300 hover:bg-cyan-500/20 transition-colors">
                            {tech}
                        </span>
                    ))}
                </div>
            )}
        </div>
    </div>
</article>

<style>
    .experience-card {
        position: relative;
        padding: 1.5rem;
        background: linear-gradient(135deg, rgba(10, 25, 47, 0.6), rgba(17, 34, 64, 0.4));
        border: 1px solid rgba(100, 255, 218, 0.1);
        border-radius: 1rem;
        transition: all 0.3s ease;
    }

    .experience-card::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(180deg, #64ffda, #0d9488);
        border-radius: 3px 0 0 3px;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .experience-card:hover {
        border-color: rgba(100, 255, 218, 0.3);
        transform: translateX(8px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .experience-card:hover::before {
        opacity: 1;
    }
</style>
