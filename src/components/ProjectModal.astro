---
interface Props {
    index: number;
    name: string;
    description: string;
    longDescription?: string;
    features?: string[];
    url: string;
    github: string;
    image: string;
    images?: string[];
    tags: string[];
}
const { index, name, description, longDescription = "", features = [], url, github, image, images = [], tags } = Astro.props;
const gallery = images.length > 0 ? images : [image];
const hasUrl = url && url !== "#";
const hasGithub = github && github !== "#";
---

<div
    id={`pm-${index}`}
    class="project-modal fixed inset-0 z-[100] hidden items-center justify-center p-4"
    role="dialog"
    aria-modal="true"
    aria-label={name}
>
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-950/90 backdrop-blur-md" data-modal-close></div>

    <!-- Contenido -->
    <div class="relative w-full max-w-3xl max-h-[90vh] overflow-y-auto bg-slate-900 rounded-2xl border border-cyan-500/30 shadow-2xl shadow-cyan-500/20">
        <!-- Botón cerrar -->
        <button
            type="button"
            data-modal-close
            class="absolute top-4 right-4 z-10 p-2 rounded-full bg-slate-900/70 border border-cyan-500/20 text-slate-300 hover:text-cyan-300 hover:border-cyan-400/50 transition-colors"
            aria-label="Cerrar"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6l-12 12"></path>
                <path d="M6 6l12 12"></path>
            </svg>
        </button>

        <!-- Galería -->
        <div class="rounded-t-2xl overflow-hidden">
            <img data-modal-main src={gallery[0]} alt={name} class="w-full h-56 sm:h-72 object-cover" />
        </div>
        {gallery.length > 1 && (
            <div class="flex gap-2 px-6 pt-4 overflow-x-auto">
                {gallery.map(src => (
                    <button type="button" data-thumb={src} class="flex-shrink-0">
                        <img src={src} alt={name} class="h-14 w-20 object-cover rounded-lg border border-cyan-500/20 hover:border-cyan-400/60 transition-colors" />
                    </button>
                ))}
            </div>
        )}

        <div class="p-6">
            <h3 class="text-2xl font-bold text-cyan-300 mb-2">{name}</h3>
            <p class="text-slate-300 leading-relaxed mb-4">{longDescription || description}</p>

            {features.length > 0 && (
                <ul class="space-y-3 mb-6">
                    {features.map(feature => (
                        <li class="flex gap-3 text-slate-400 text-sm leading-relaxed">
                            <svg xmlns="http://www.w3.org/2000/svg" class="size-5 flex-shrink-0 text-cyan-400 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 12l2 2l4 -4"></path>
                                <path d="M12 21a9 9 0 1 1 0 -18a9 9 0 0 1 0 18z"></path>
                            </svg>
                            <span>{feature}</span>
                        </li>
                    ))}
                </ul>
            )}

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-6">
                {tags.map(tag => (
                    <span class="text-xs px-3 py-1 bg-cyan-500/10 border border-cyan-500/20 rounded-full text-cyan-300">{tag}</span>
                ))}
            </div>

            <!-- Acciones -->
            {(hasUrl || hasGithub) && (
                <div class="flex flex-wrap gap-3">
                    {hasGithub && (
                        <a href={github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-cyan-500/20 to-teal-500/20 border border-cyan-500/30 rounded-xl text-cyan-200 hover:border-cyan-400/50 transition-colors">
                            <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                                <path fill-rule="evenodd" d="M12.006 2a9.847 9.847 0 0 0-6.484 2.44 10.32 10.32 0 0 0-3.393 6.17 10.48 10.48 0 0 0 1.317 6.955 10.045 10.045 0 0 0 5.4 4.418c.504.095.683-.223.683-.494 0-.245-.01-1.052-.014-1.908-2.78.62-3.366-1.21-3.366-1.21a2.711 2.711 0 0 0-1.11-1.5c-.907-.637.07-.621.07-.621.317.044.62.163.885.346.266.183.487.426.647.71.135.253.318.476.538.655a2.079 2.079 0 0 0 2.37.196c.045-.52.27-1.006.635-1.37-2.219-.259-4.554-1.138-4.554-5.07a4.022 4.022 0 0 1 1.031-2.75 3.77 3.77 0 0 1 .096-2.713s.839-.275 2.749 1.05a9.26 9.26 0 0 1 5.004 0c1.906-1.325 2.74-1.05 2.74-1.05.37.858.406 1.828.101 2.713a4.017 4.017 0 0 1 1.029 2.75c0 3.939-2.339 4.805-4.564 5.058a2.471 2.471 0 0 1 .679 1.897c0 1.372-.012 2.477-.012 2.814 0 .272.18.592.687.492a10.05 10.05 0 0 0 5.388-4.421 10.473 10.473 0 0 0 1.313-6.948 10.32 10.32 0 0 0-3.39-6.165A9.847 9.847 0 0 0 12.007 2Z" clip-rule="evenodd"/>
                            </svg>
                            Ver código
                        </a>
                    )}
                    {hasUrl && url !== github && (
                        <a href={url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-800/60 border border-slate-600/40 rounded-xl text-slate-200 hover:border-cyan-400/50 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                            </svg>
                            Ver sitio
                        </a>
                    )}
                </div>
            )}
        </div>
    </div>
</div>
