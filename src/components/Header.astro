---
import HomeIcon from './icons/iconsNav/HomeIcon.astro'
import ProjectsIcon from './icons/iconsNav/ProjectsIcon.astro'
import ExperienceNavIcon from './icons/iconsNav/ExperienceNavIcon.astro'
import SkillsIcon from './icons/iconsNav/SkillsIcon.astro'
import FormationNavIcon from './icons/iconsNav/FormationNavIcon.astro'
import UserIcon from './icons/iconsNav/UserIcon.astro'
import ContactIcon from './icons/iconsNav/ContactIcon.astro'
import MenuIcon from './icons/iconsNav/MenuIcon.astro'
import CloseIcon from './icons/iconsNav/CloseIcon.astro'

const navItems = [
    { href: "#home", icon: HomeIcon, label: "Inicio" },
    { href: "#projects", icon: ProjectsIcon, label: "Proyectos" },
    { href: "#experience", icon: ExperienceNavIcon, label: "Experiencia" },
    { href: "#skills", icon: SkillsIcon, label: "Habilidades" },
    { href: "#formation", icon: FormationNavIcon, label: "Formación" },
    { href: "#about", icon: UserIcon, label: "Sobre mi" },
    { href: "#contact", icon: ContactIcon, label: "Contacto" },
]
---

<!-- Sidebar para desktop -->
<nav class="sidebar">
    {navItems.map(({ href, icon: Icon, label }) => (
        <a href={href} class="nav-item" title={label}>
            <Icon class="nav-icon" />
            <span class="nav-label">{label}</span>
        </a>
    ))}
</nav>

<!-- Botón hamburguesa para móvil -->
<button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Abrir menú">
    <MenuIcon class="menu-icon" id="menu-icon" />
    <CloseIcon class="close-icon is-hidden" id="close-icon" />
</button>

<!-- Menú móvil overlay -->
<div class="mobile-menu is-hidden" id="mobile-menu">
    <nav class="mobile-nav">
        {navItems.map(({ href, icon: Icon, label }) => (
            <a href={href} class="mobile-nav-item">
                <Icon class="mobile-nav-icon" />
                <span>{label}</span>
            </a>
        ))}
    </nav>
</div>

<style>
    /* Clase para ocultar elementos */
    .is-hidden {
        display: none !important;
    }

    /* Sidebar Desktop - oculto en móvil, visible en desktop */
    .sidebar {
        display: none;
        position: fixed;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        flex-direction: column;
        background: rgba(10, 25, 47, 0.9);
        backdrop-filter: blur(10px);
        border-right: 1px solid rgba(100, 255, 218, 0.1);
        border-radius: 0 12px 12px 0;
        padding: 1rem 0.5rem;
        gap: 0.5rem;
        z-index: 100;
        width: 60px;
        transition: width 0.3s ease;
        overflow: hidden;
    }

    @media (min-width: 768px) {
        .sidebar {
            display: flex;
        }
        .mobile-menu-btn {
            display: none;
        }
    }

    .sidebar:hover {
        width: 180px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        color: #8892b0;
        text-decoration: none;
        border-radius: 8px;
        transition: all 0.2s ease;
        white-space: nowrap;
    }

    .nav-item:hover {
        background: rgba(100, 255, 218, 0.1);
        color: #64ffda;
    }

    .nav-item.active {
        background: rgba(100, 255, 218, 0.12);
        color: #64ffda;
        box-shadow: inset 3px 0 0 #64ffda;
    }

    .nav-icon {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
    }

    .nav-label {
        opacity: 0;
        transition: opacity 0.3s ease;
        font-size: 0.875rem;
    }

    .sidebar:hover .nav-label {
        opacity: 1;
    }

    /* Botón menú móvil - visible solo en móvil */
    .mobile-menu-btn {
        position: fixed;
        top: 1rem;
        right: 1rem;
        z-index: 110;
        background: rgba(10, 25, 47, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(100, 255, 218, 0.2);
        border-radius: 8px;
        padding: 0.75rem;
        color: #64ffda;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .mobile-menu-btn:hover {
        background: rgba(100, 255, 218, 0.1);
    }

    .menu-icon,
    .close-icon {
        width: 24px;
        height: 24px;
    }

    /* Menú móvil overlay */
    .mobile-menu {
        position: fixed;
        inset: 0;
        background: rgba(10, 25, 47, 0.98);
        backdrop-filter: blur(10px);
        z-index: 105;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .mobile-nav {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        text-align: center;
    }

    .mobile-nav-item {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        padding: 1rem 2rem;
        color: #ccd6f6;
        text-decoration: none;
        font-size: 1.25rem;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

    .mobile-nav-item:hover {
        background: rgba(100, 255, 218, 0.1);
        color: #64ffda;
    }

    .mobile-nav-icon {
        width: 28px;
        height: 28px;
    }
</style>

<script>
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    const mobileNavItems = document.querySelectorAll('.mobile-nav-item');

    function toggleMenu() {
        mobileMenu?.classList.toggle('is-hidden');
        menuIcon?.classList.toggle('is-hidden');
        closeIcon?.classList.toggle('is-hidden');
        document.body.style.overflow = mobileMenu?.classList.contains('is-hidden') ? '' : 'hidden';
    }

    mobileMenuBtn?.addEventListener('click', toggleMenu);

    mobileNavItems.forEach(item => {
        item.addEventListener('click', () => {
            toggleMenu();
        });
    });

    // Resaltar la sección activa en el sidebar
    const sections = document.querySelectorAll('main section[id]');
    const navItems = document.querySelectorAll<HTMLAnchorElement>('.sidebar .nav-item');

    const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const id = entry.target.getAttribute('id');
            navItems.forEach(item => {
                item.classList.toggle('active', item.getAttribute('href') === `#${id}`);
            });
        });
    }, { rootMargin: '-45% 0px -45% 0px' });

    sections.forEach(section => sectionObserver.observe(section));
</script>
