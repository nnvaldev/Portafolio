---
interface Props {
    name: string;
    description: string;
    url: string;
    github: string;
    image: string;
    tags: string[];
    wip?: boolean;
    index?: number;
}
const { name, description, url, github, image, tags, wip = false, index = 0 } = Astro.props;
const hasUrl = url && url !== "#" && url !== github;
const hasGithub = github && github !== "#";
---

<article
    class:list={["project-card group", !wip && "cursor-pointer"]}
    data-modal-open={!wip ? `pm-${index}` : undefined}
    data-tilt
>
    <!-- Imagen con overlay -->
    <div class="relative overflow-hidden rounded-t-2xl">
        <img
            class:list={["w-full h-48 object-cover transition-transform duration-500 group-hover:scale-110", wip && "blur-sm grayscale opacity-50"]}
            src={image}
            alt={name}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

        {wip && (
            <div class="absolute inset-0 flex items-center justify-center">
                <span class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-amber-500/20 text-amber-300 rounded-full border border-amber-500/40 backdrop-blur-sm">
                    🚧 En construcción
                </span>
            </div>
        )}

        {(hasUrl || hasGithub) && (
            <!-- Overlay links -->
            <div class="absolute inset-0 flex items-center justify-center gap-4 opacity-0 group-hover:opacity-100 transition-all duration-300">
                {hasUrl && (
                    <a
                        href={url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-3 bg-cyan-500/20 backdrop-blur-sm border border-cyan-500/30 rounded-full text-cyan-300 hover:bg-cyan-500/40 hover:scale-110 transition-all"
                        title="Ver sitio"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                    </a>
                )}
                {hasGithub && (
                    <a
                        href={github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-3 bg-cyan-500/20 backdrop-blur-sm border border-cyan-500/30 rounded-full text-cyan-300 hover:bg-cyan-500/40 hover:scale-110 transition-all"
                        title="Ver codigo"
                    >
                        <svg class="size-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                            <path fill-rule="evenodd" d="M12.006 2a9.847 9.847 0 0 0-6.484 2.44 10.32 10.32 0 0 0-3.393 6.17 10.48 10.48 0 0 0 1.317 6.955 10.045 10.045 0 0 0 5.4 4.418c.504.095.683-.223.683-.494 0-.245-.01-1.052-.014-1.908-2.78.62-3.366-1.21-3.366-1.21a2.711 2.711 0 0 0-1.11-1.5c-.907-.637.07-.621.07-.621.317.044.62.163.885.346.266.183.487.426.647.71.135.253.318.476.538.655a2.079 2.079 0 0 0 2.37.196c.045-.52.27-1.006.635-1.37-2.219-.259-4.554-1.138-4.554-5.07a4.022 4.022 0 0 1 1.031-2.75 3.77 3.77 0 0 1 .096-2.713s.839-.275 2.749 1.05a9.26 9.26 0 0 1 5.004 0c1.906-1.325 2.74-1.05 2.74-1.05.37.858.406 1.828.101 2.713a4.017 4.017 0 0 1 1.029 2.75c0 3.939-2.339 4.805-4.564 5.058a2.471 2.471 0 0 1 .679 1.897c0 1.372-.012 2.477-.012 2.814 0 .272.18.592.687.492a10.05 10.05 0 0 0 5.388-4.421 10.473 10.473 0 0 0 1.313-6.948 10.32 10.32 0 0 0-3.39-6.165A9.847 9.847 0 0 0 12.007 2Z" clip-rule="evenodd"/>
                        </svg>
                    </a>
                )}
            </div>
        )}
    </div>

    <!-- Contenido -->
    <div class="p-5">
        <h3 class="text-xl font-bold text-cyan-300 mb-2 group-hover:text-cyan-200 transition-colors">
            {name}
        </h3>
        <p class="text-slate-400 text-sm mb-4 line-clamp-3">
            {description}
        </p>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2">
            {tags.slice(0, 5).map(tag => (
                <span class="text-xs px-3 py-1 bg-cyan-500/10 border border-cyan-500/20 rounded-full text-cyan-300">
                    {tag}
                </span>
            ))}
            {tags.length > 5 && (
                <span class="text-xs px-3 py-1 bg-slate-700/50 rounded-full text-slate-400">
                    +{tags.length - 5}
                </span>
            )}
        </div>

        {!wip && (
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-cyan-400 group-hover:text-cyan-300 group-hover:gap-2 transition-all">
                Ver detalles
                <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12l14 0"></path>
                    <path d="M13 18l6 -6"></path>
                    <path d="M13 6l6 6"></path>
                </svg>
            </span>
        )}
    </div>

    <!-- Glow que sigue el cursor -->
    <div class="card-glow"></div>
</article>

<style>
    .project-card {
        position: relative;
        background: linear-gradient(135deg, rgba(10, 25, 47, 0.8), rgba(17, 34, 64, 0.6));
        border: 1px solid rgba(100, 255, 218, 0.1);
        border-radius: 1rem;
        overflow: hidden;
        transform-style: preserve-3d;
        transition: transform 0.15s ease-out, box-shadow 0.4s ease, border-color 0.4s ease;
    }

    .project-card:hover {
        border-color: rgba(100, 255, 218, 0.35);
        box-shadow:
            0 24px 50px rgba(0, 0, 0, 0.4),
            0 0 50px rgba(100, 255, 218, 0.12);
    }

    /* Glow radial que sigue el cursor */
    .card-glow {
        position: absolute;
        inset: 0;
        z-index: 2;
        pointer-events: none;
        border-radius: inherit;
        opacity: 0;
        transition: opacity 0.3s ease;
        background: radial-gradient(
            240px circle at var(--gx, 50%) var(--gy, 50%),
            rgba(100, 255, 218, 0.14),
            transparent 60%
        );
    }

    .project-card:hover .card-glow {
        opacity: 1;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
