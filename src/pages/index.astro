---
import Layout from '../layouts/Layout.astro'
import Badge from '../components/Badge.astro'
import LinkedIn from '../components/icons/iconsHead/LinkedIn.astro'
import GitHub from '../components/icons/iconsHead/GitHub.astro'
import SocialPill from '../components/icons/SocialPill.astro'
import SocialPill2 from '../components/icons/SocialPill2.astro'
import Mail from '../components/icons/iconsHead/Mail.astro'
import Curriculum from '../components/icons/iconsHead/Curriculum.astro'
import Formation from '../components/Formation.astro'
import Css from '../components/icons/iconsSkills/Css.astro'
import React from '../components/icons/iconsSkills/React.astro'
import Tailwind from '../components/icons/iconsSkills/Tailwind.astro'
import Laravel from '../components/icons/iconsSkills/Laravel.astro'
import TypeScript from '../components/icons/iconsSkills/TypeScript.astro'
import DataBase from '../components/icons/iconsSkills/DataBase.astro'
import Python from '../components/icons/iconsSkills/Python.astro'
import Git from '../components/icons/iconsSkills/Git.astro'
import Docker from '../components/icons/iconsSkills/Docker.astro'
import Node from '../components/icons/iconsSkills/Node.astro'
import Php from '../components/icons/iconsSkills/Php.astro'
import JavaScript from '../components/icons/iconsSkills/JavaScript.astro'
import AstroIcon from '../components/icons/iconsSkills/AstroIcon.astro'
import Html from '../components/icons/iconsSkills/Html.astro'
import Aws from '../components/icons/iconsSkills/Aws.astro'
import FastApi from '../components/icons/iconsSkills/FastApi.astro'
import Flutter from '../components/icons/iconsSkills/Flutter.astro'
import Figma from '../components/icons/iconsSkills/Figma.astro'
import Skill from '../components/icons/iconsSkills/Skill.astro'
import Container from '../components/Container.astro'
import FormationIcon from '../components/icons/FormationIcon.astro'
import ProjectIcon from '../components/icons/ProjectIcon.astro'
import Project from '../components/Project.astro'
import ExperienceIcon from '../components/icons/ExperienceIcon.astro'
import Experience from '../components/Experience.astro'
import Stats from '../components/Stats.astro'
---

<Layout title='Alexander Castillo (nvaldev) — Fullstack & Cloud Engineer'
	description='Alexander Castillo (nvaldev) es Fullstack & Cloud Engineer de La Paz, Bolivia. Especializado en arquitecturas Cloud en AWS (Fargate, CDK), CI/CD, TypeScript y desarrollo mobile con Flutter.'>

	<!-- Fondo decorativo -->
	<div class="fixed inset-0 -z-10 overflow-hidden">
		<div class="absolute top-1/4 -left-20 w-72 h-72 bg-cyan-500/10 rounded-full blur-3xl"></div>
		<div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl"></div>
		<div class="absolute top-3/4 left-1/3 w-64 h-64 bg-cyan-400/5 rounded-full blur-3xl"></div>
	</div>

	<main class="px-4 md:pl-20">
		<!-- Hero Section -->
		<Container id="home" class="min-h-screen flex flex-col justify-center py-20">
			<div class="hero-content" style="animation: fadeInUp 0.8s ease-out;">
				<!-- Foto con efecto glow -->
				<div class="flex justify-center mb-8">
					<div class="relative group">
						<div class="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-teal-500 rounded-full blur opacity-30 group-hover:opacity-60 transition duration-500"></div>
						<img
							class="relative rounded-full w-28 h-28 sm:w-36 sm:h-36 md:w-44 md:h-44 object-cover ring-2 ring-cyan-500/30"
							src="https://d2zia2w5autnlg.cloudfront.net/52261/profile-5f5d81c85f82b-small"
							alt="nvaldev photo"
						/>
					</div>
				</div>

				<!-- Badge animado -->
				<div class="flex justify-center mb-6" style="animation: fadeInUp 0.8s ease-out 0.1s both;">
					<Badge>
						<span class="relative flex h-2 w-2 mr-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
						</span>
						<a href="https://www.linkedin.com/in/nvaldev/" target="_blank">
							Disponible para trabajar
						</a>
					</Badge>
				</div>

				<!-- Nombre con gradiente -->
				<h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-center mb-2" style="animation: fadeInUp 0.8s ease-out 0.2s both;">
					<span class="text-slate-100">Hola, soy </span>
					<span class="gradient-text">Alexander Castillo</span>
				</h1>
				<p class="text-center text-slate-500 font-mono mb-4" style="animation: fadeInUp 0.8s ease-out 0.25s both;">@nvaldev</p>

				<!-- Typing effect -->
				<div class="text-center mb-6" style="animation: fadeInUp 0.8s ease-out 0.3s both;">
					<h2 class="text-xl sm:text-2xl md:text-3xl text-slate-300">
						<span class="text-cyan-400 font-semibold" id="typing-text"></span>
						<span class="typing-cursor">|</span>
					</h2>
				</div>

				<!-- Descripción -->
				<p class="text-lg text-slate-400 text-center max-w-2xl mx-auto mb-8" style="animation: fadeInUp 0.8s ease-out 0.4s both;">
					Fullstack & Cloud Engineer de <span class="text-cyan-300">La Paz, Bolivia</span>.
					Diseño e implemento arquitecturas <span class="text-cyan-300">Cloud en AWS</span> (Fargate, CDK),
					automatizo CI/CD y construyo apps web y mobile de alto impacto.
				</p>

				<!-- Social pills con animación escalonada -->
				<nav class="flex flex-wrap justify-center gap-4" style="animation: fadeInUp 0.8s ease-out 0.5s both;">
					<SocialPill href="/cv_es.pdf">
						<Curriculum class="size-4" />
						Curriculum
					</SocialPill>
					<SocialPill href="https://www.linkedin.com/in/nvaldev/">
						<LinkedIn class="size-4" />
						LinkedIn
					</SocialPill>
					<SocialPill href="https://github.com/nnvaldev">
						<GitHub class="size-4" />
						GitHub
					</SocialPill>
					<SocialPill href="mailto:nnvaldev@gmail.com">
						<Mail class="size-4" />
						nnvaldev@gmail.com
					</SocialPill>
				</nav>

				<!-- Scroll indicator -->
				<div class="flex justify-center mt-16" style="animation: fadeInUp 0.8s ease-out 0.6s both;">
					<a href="#projects" class="scroll-indicator">
						<svg xmlns="http://www.w3.org/2000/svg" class="size-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
						</svg>
					</a>
				</div>
			</div>
		</Container>

		<!-- Stats + Marquee -->
		<div class="animate-on-scroll">
			<Stats />
		</div>

		<!-- Proyectos -->
		<Container id="projects" class="py-20">
			<div class="animate-on-scroll">
				<h2 class="text-3xl md:text-4xl text-slate-100 font-bold mb-2 flex gap-x-3 items-center">
					<ProjectIcon class="size-10 text-cyan-400" />
					<span>Proyectos</span>
				</h2>
				<p class="text-slate-400 mb-10">Algunos de mis trabajos recientes</p>
			</div>
			<div class="animate-on-scroll animate-delay-200">
				<Project />
			</div>
		</Container>

		<!-- Experiencia Laboral -->
		<Container id="experience" class="py-20">
			<div class="animate-on-scroll">
				<h2 class="text-3xl md:text-4xl text-slate-100 font-bold mb-2 flex gap-x-3 items-center">
					<ExperienceIcon class="size-10 text-cyan-400" />
					<span>Experiencia Laboral</span>
				</h2>
				<p class="text-slate-400 mb-10">Mi trayectoria profesional</p>
			</div>
			<div class="animate-on-scroll animate-delay-200">
				<Experience />
			</div>
		</Container>

		<!-- Habilidades -->
		<Container id="skills" class="py-20">
			<div class="animate-on-scroll">
				<h2 class="text-3xl md:text-4xl text-slate-100 font-bold mb-2 flex gap-x-3 items-center">
					<Skill class="size-10 text-cyan-400"/>
					<span>Habilidades</span>
				</h2>
				<p class="text-slate-400 mb-10">Tecnologias con las que trabajo</p>
			</div>
			<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 animate-on-scroll animate-delay-200">
				<SocialPill2>
					<Html class="size-6" />
					HTML
				</SocialPill2>
				<SocialPill2>
					<Css class="size-6" />
					CSS
				</SocialPill2>
				<SocialPill2>
					<JavaScript class="size-6" />
					JavaScript
				</SocialPill2>
				<SocialPill2>
					<TypeScript class="size-6" />
					TypeScript
				</SocialPill2>
				<SocialPill2>
					<React class="size-6" />
					React
				</SocialPill2>
				<SocialPill2>
					<Tailwind class="size-6" />
					Tailwind
				</SocialPill2>
				<SocialPill2>
					<AstroIcon class="size-6" />
					Astro
				</SocialPill2>
				<SocialPill2>
					<Node class="size-6" />
					NodeJS
				</SocialPill2>
				<SocialPill2>
					<Laravel class="size-6" />
					Laravel
				</SocialPill2>
				<SocialPill2>
					<Php class="size-6" />
					PHP
				</SocialPill2>
				<SocialPill2>
					<Python class="size-6" />
					Python
				</SocialPill2>
				<SocialPill2>
					<DataBase class="size-6" />
					SQL
				</SocialPill2>
				<SocialPill2>
					<Git class="size-6" />
					Git
				</SocialPill2>
				<SocialPill2>
					<Docker class="size-6" />
					Docker
				</SocialPill2>
				<SocialPill2>
					<Aws class="size-6" />
					AWS
				</SocialPill2>
				<SocialPill2>
					<FastApi class="size-6" />
					FastAPI
				</SocialPill2>
				<SocialPill2>
					<Flutter class="size-6" />
					Flutter
				</SocialPill2>
				<SocialPill2>
					<Figma class="size-6" />
					Figma
				</SocialPill2>
			</div>
		</Container>

		<!-- Formación -->
		<Container id="formation" class="py-20">
			<div class="animate-on-scroll">
				<h2 class="text-3xl md:text-4xl text-slate-100 font-bold mb-2 flex gap-x-3 items-center">
					<FormationIcon class="size-10 text-cyan-400"/>
					<span>Formacion Academica</span>
				</h2>
				<p class="text-slate-400 mb-10">Mi trayectoria educativa</p>
			</div>
			<div class="animate-on-scroll animate-delay-200">
				<Formation />
			</div>
		</Container>

		<!-- Sobre mi -->
		<Container id="about" class="py-20">
			<div class="animate-on-scroll">
				<h2 class="text-3xl md:text-4xl text-slate-100 font-bold mb-2 flex gap-x-3 items-center">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" class="size-10 text-cyan-400" stroke-width="2">
						<path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0"></path>
						<path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"></path>
					</svg>
					<span>Sobre mi</span>
				</h2>
			</div>
			<div class="animate-on-scroll animate-delay-200 mt-8">
				<div class="glass rounded-2xl p-8 max-w-3xl">
					<p class="text-lg text-slate-300 leading-relaxed mb-4">
						Soy <span class="text-cyan-300 font-medium">Ingeniero de Software</span> con un perfil
						híbrido avanzado: combino el desarrollo <span class="text-cyan-300 font-medium">Fullstack</span>,
						la automatización de infraestructura (<span class="text-cyan-300 font-medium">DevOps / IaC</span>)
						y el diseño <span class="text-cyan-300 font-medium">UI/UX</span>.
					</p>
					<p class="text-lg text-slate-300 leading-relaxed mb-4">
						Me especializo en diseñar e implementar arquitecturas modernas en la nube con
						<span class="text-cyan-300 font-medium">AWS (Fargate, CDK)</span>, garantizando alta
						disponibilidad, observabilidad y despliegues continuos automatizados (CI/CD). Tengo
						experiencia robusta en backend con <span class="text-cyan-300 font-medium">Python (FastAPI)</span>,
						<span class="text-cyan-300 font-medium">Node.js</span> y <span class="text-cyan-300 font-medium">Laravel</span>,
						desarrollo mobile con <span class="text-cyan-300 font-medium">Flutter</span> y su distribución
						en App Store y Google Play, y paneles web con <span class="text-cyan-300 font-medium">React / TypeScript</span>.
					</p>
					<p class="text-lg text-slate-300 leading-relaxed">
						Me apasiona resolver problemas complejos de concurrencia, diseñar sistemas de diseño
						robustos en Figma y alinear la ingeniería técnica con los objetivos de negocio.
					</p>
				</div>
			</div>
		</Container>

		<!-- Contacto -->
		<Container id="contact" class="py-20 pb-32">
			<div class="animate-on-scroll">
				<h2 class="text-3xl md:text-4xl text-slate-100 font-bold mb-2 flex gap-x-3 items-center">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" class="size-10 text-cyan-400" stroke-width="2">
						<path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"></path>
						<path d="M3 7l9 6l9 -6"></path>
					</svg>
					<span>Contacto</span>
				</h2>
				<p class="text-slate-400 mb-10">Hablemos sobre tu proyecto</p>
			</div>
			<div class="animate-on-scroll animate-delay-200">
				<div class="glass rounded-2xl p-8 max-w-2xl">
					<p class="text-xl text-slate-300 mb-8">
						¿Tienes un proyecto en mente? ¡Me encantaria escucharte!
					</p>
					<div class="flex flex-wrap gap-4">
						<a href="mailto:nnvaldev@gmail.com" class="group inline-flex items-center gap-3 px-6 py-4 bg-gradient-to-r from-cyan-500/20 to-teal-500/20 border border-cyan-500/30 rounded-xl text-cyan-200 hover:border-cyan-400/50 hover:from-cyan-500/30 hover:to-teal-500/30 transition-all duration-300 shine-effect">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" class="size-6 group-hover:scale-110 transition-transform" stroke-width="2">
								<path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"></path>
								<path d="M3 7l9 6l9 -6"></path>
							</svg>
							<span class="font-medium">nnvaldev@gmail.com</span>
						</a>
						<a href="https://www.linkedin.com/in/nvaldev/" target="_blank" class="group inline-flex items-center gap-3 px-6 py-4 bg-gradient-to-r from-cyan-500/20 to-teal-500/20 border border-cyan-500/30 rounded-xl text-cyan-200 hover:border-cyan-400/50 hover:from-cyan-500/30 hover:to-teal-500/30 transition-all duration-300 shine-effect">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6 group-hover:scale-110 transition-transform">
								<path d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z"></path>
								<path d="M8 11l0 5"></path>
								<path d="M8 8l0 .01"></path>
								<path d="M12 16l0 -5"></path>
								<path d="M16 16v-3a2 2 0 0 0 -4 0"></path>
							</svg>
							<span class="font-medium">LinkedIn</span>
						</a>
					</div>
				</div>
			</div>
		</Container>
	</main>
</Layout>

<style>
	.typing-cursor {
		animation: blink-caret 0.75s step-end infinite;
		color: #64ffda;
	}

	@keyframes blink-caret {
		from, to { opacity: 1; }
		50% { opacity: 0; }
	}

	.scroll-indicator {
		animation: float 2s ease-in-out infinite;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(10px); }
	}
</style>

<script>
	// Efecto typing
	const texts = [
		"Fullstack & Cloud Engineer",
		"Cloud Architect · AWS (Fargate, CDK)",
		"DevOps · CI/CD · IaC",
		"Mobile Developer · Flutter",
			"UI/UX Designer · Figma"
	];

	let textIndex = 0;
	let charIndex = 0;
	let isDeleting = false;
	const typingElement = document.getElementById('typing-text');

	function type() {
		if (!typingElement) return;

		const currentText = texts[textIndex];

		if (isDeleting) {
			typingElement.textContent = currentText.substring(0, charIndex - 1);
			charIndex--;
		} else {
			typingElement.textContent = currentText.substring(0, charIndex + 1);
			charIndex++;
		}

		let typeSpeed = isDeleting ? 50 : 100;

		if (!isDeleting && charIndex === currentText.length) {
			typeSpeed = 2000;
			isDeleting = true;
		} else if (isDeleting && charIndex === 0) {
			isDeleting = false;
			textIndex = (textIndex + 1) % texts.length;
			typeSpeed = 500;
		}

		setTimeout(type, typeSpeed);
	}

	type();
</script>
